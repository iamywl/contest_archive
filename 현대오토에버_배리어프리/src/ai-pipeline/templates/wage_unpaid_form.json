{
  "form_type": "wage_unpaid",
  "form_title_ko": "임금체불 진정서",
  "form_title_en": "Wage Theft Complaint",
  "official_source": "고용노동부 민원마당 (https://minwon.moel.go.kr)",
  "fields": {
    "applicant_name_ko": {"label_ko": "진정인 성명 (한국어)", "type": "string", "required": true, "example": "비크람 라이"},
    "applicant_name_native": {"label_ko": "진정인 성명 (모국어)", "type": "string", "required": true, "example": "Bikram Rai"},
    "applicant_nationality": {"label_ko": "국적", "type": "string", "required": true, "example": "네팔"},
    "applicant_visa": {"label_ko": "체류자격", "type": "string", "required": true, "example": "E-9"},
    "applicant_phone": {"label_ko": "연락처", "type": "string", "required": true, "example": "010-XXXX-XXXX"},
    "employer_name": {"label_ko": "사업장명 (체불자)", "type": "string", "required": true, "example": "○○농장"},
    "employer_representative": {"label_ko": "대표자 성명", "type": "string", "required": false, "example": "김○○"},
    "employer_address": {"label_ko": "사업장 소재지", "type": "string", "required": true, "example": "충청남도 ○○군 ○○면 ○○로 123"},
    "employment_start": {"label_ko": "근로계약 시작일", "type": "date", "required": true, "example": "2022-08-01"},
    "employment_end": {"label_ko": "근로계약 종료일 (해당 시)", "type": "date", "required": false, "example": ""},
    "wage_unpaid_period_start": {"label_ko": "임금체불 시작 시점", "type": "date", "required": true, "example": "2026-01-01"},
    "wage_unpaid_period_end": {"label_ko": "임금체불 종료 시점", "type": "date", "required": true, "example": "2026-03-31"},
    "wage_unpaid_amount_won": {"label_ko": "체불 금액 (원)", "type": "integer", "required": true, "example": 3800000},
    "wage_unpaid_breakdown": {"label_ko": "체불 내역", "type": "text", "required": true, "example": "2026년 1월 임금 1,200,000원 / 2월 임금 1,300,000원 / 3월 임금 1,300,000원 합계 3,800,000원"},
    "evidence_summary": {"label_ko": "첨부 증거 요약", "type": "string", "required": false, "example": "근로계약서 사본, 통장 거래내역(미입금 확인), 카카오톡 임금 독촉 메시지, 출퇴근 GPS 기록"},
    "complaint_request": {"label_ko": "진정 요지", "type": "text", "required": true, "example": "위 체불 임금 3,800,000원의 즉시 지급 및 근로기준법 위반에 대한 적절한 행정조치를 요청합니다."}
  },
  "writing_examples": [
    {
      "scenario": "농업 임금체불 3개월",
      "good_example_korean": "진정인은 2022년 8월 1일부터 ○○농장에서 농업 노동자로 근무해왔으나, 사업주는 2026년 1월부터 3월까지 3개월간의 임금 합계 3,800,000원을 정당한 사유 없이 지급하지 않고 있습니다. 진정인은 매월 임금 지급일에 사업주에게 지급을 요청하였으나 '한 달만 더 기다려 달라'는 답변만 8회 반복되었습니다. 이에 근로기준법 제43조(임금 지급) 및 제36조(금품 청산) 위반으로 진정합니다."
    }
  ]
}
